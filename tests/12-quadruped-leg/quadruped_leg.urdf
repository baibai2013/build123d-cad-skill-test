<?xml version="1.0" encoding="utf-8"?>
<!--
  Quadruped Single Leg URDF (1:5 scale from reference drawing)
  Generated by build123d-cad skill for PyBullet simulation.

  Reference mass/inertia (original scale):
    femur:  m=1.55kg,  I=80.9 kg*cm^2
    tibia:  m=0.157kg, I=13.1 kg*cm^2
    foot:   m=0.116kg, I=7.4  kg*cm^2

  At 1:5 scale, mass scales by (1/5)^3 = 1/125.
  Simplified box inertia used for simulation stability.
-->
<robot name="quadruped_leg">

  <!-- ===== Links ===== -->

  <!-- Hip mount: motor housing disc -->
  <link name="hip_mount">
    <visual>
      <geometry>
        <cylinder radius="0.018" length="0.008"/>
      </geometry>
      <material name="gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.018" length="0.008"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="4.5e-6" ixy="0" ixz="0" iyy="4.5e-6" iyz="0" izz="8.1e-6"/>
    </inertial>
  </link>

  <!-- Femur: upper leg plate (50x18x4mm) -->
  <link name="femur">
    <visual>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.004 0.018 0.050"/>
      </geometry>
      <material name="steelblue">
        <color rgba="0.27 0.51 0.71 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.004 0.018 0.050"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.025"/>
      <mass value="0.012"/>
      <inertia ixx="2.6e-6" ixy="0" ixz="0" iyy="2.5e-6" iyz="0" izz="2.7e-7"/>
    </inertial>
  </link>

  <!-- Tibia: lower leg plate (45x16x3mm) -->
  <link name="tibia">
    <visual>
      <origin xyz="0 0 -0.0225" rpy="0 0 0"/>
      <geometry>
        <box size="0.003 0.016 0.045"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.65 0.0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0225" rpy="0 0 0"/>
      <geometry>
        <box size="0.003 0.016 0.045"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.0225"/>
      <mass value="0.005"/>
      <inertia ixx="8.6e-7" ixy="0" ixz="0" iyy="8.4e-7" iyz="0" izz="1.1e-7"/>
    </inertial>
  </link>

  <!-- Metatarsus: foot bone plate (17x10x3mm) -->
  <link name="metatarsus">
    <visual>
      <origin xyz="0 0 -0.0085" rpy="0 0 0"/>
      <geometry>
        <box size="0.003 0.010 0.017"/>
      </geometry>
      <material name="dodgerblue">
        <color rgba="0.12 0.56 1.0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0085" rpy="0 0 0"/>
      <geometry>
        <box size="0.003 0.010 0.017"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.0085"/>
      <mass value="0.001"/>
      <inertia ixx="2.5e-8" ixy="0" ixz="0" iyy="2.5e-8" iyz="0" izz="8.3e-9"/>
    </inertial>
  </link>

  <!-- Foot pad: wide plate (36x12x3mm) -->
  <link name="foot_pad">
    <visual>
      <origin xyz="0 0 -0.006" rpy="0 0 0"/>
      <geometry>
        <box size="0.003 0.036 0.012"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.5 0.0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.006" rpy="0 0 0"/>
      <geometry>
        <box size="0.003 0.036 0.012"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 -0.006"/>
      <mass value="0.003"/>
      <inertia ixx="9.3e-7" ixy="0" ixz="0" iyy="3.4e-8" iyz="0" izz="9.0e-7"/>
    </inertial>
  </link>

  <!-- ===== Joints ===== -->

  <!-- Hip joint: hip_mount -> femur (Y-axis rotation) -->
  <joint name="hip_joint" type="revolute">
    <parent link="hip_mount"/>
    <child link="femur"/>
    <origin xyz="0 0 -0.004" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.7854" upper="0.7854" effort="10" velocity="5"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <!-- Knee joint: femur -> tibia (Y-axis rotation) -->
  <joint name="knee_joint" type="revolute">
    <parent link="femur"/>
    <child link="tibia"/>
    <origin xyz="0 0 -0.050" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="0" effort="10" velocity="5"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <!-- Ankle joint: tibia -> metatarsus (Y-axis rotation) -->
  <joint name="ankle_joint" type="revolute">
    <parent link="tibia"/>
    <child link="metatarsus"/>
    <origin xyz="0 0 -0.045" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.5236" upper="0.5236" effort="5" velocity="5"/>
    <dynamics damping="0.005" friction="0.002"/>
  </joint>

  <!-- Foot joint: metatarsus -> foot_pad (fixed) -->
  <joint name="foot_joint" type="fixed">
    <parent link="metatarsus"/>
    <child link="foot_pad"/>
    <origin xyz="0 0 -0.017" rpy="0 0 0"/>
  </joint>

</robot>
